# LLM de recommandation (API compatible OpenAI).
# VM "Configurable Call Center LLM" via devtunnel, ou un Ollama local.
LLM_BASE_URL=https://zf04gvh1-8020.uks1.devtunnels.ms/v1
LLM_MODEL=essilor-recommendation-v1
LLM_API_KEY=optiguide
USE_LLM_AGENT=1
LLM_TIMEOUT=30
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=250

# Base de la VM pour les endpoints natifs (/chat/recommendation, /v1/catalogue/search).
VM_BASE_URL=https://zf04gvh1-8020.uks1.devtunnels.ms

# Supabase (base de donnees produits + annotations expert).
# Laisser vide pour faire tourner l'app en local sans base (mode degrade).
SUPABASE_URL=
SUPABASE_KEY=
