# Modele de secrets pour Streamlit Cloud / local.
# Copier vers .streamlit/secrets.toml (deja gitignore) OU coller le contenu
# dans Streamlit Cloud > App > Settings > Secrets.
#
# Utiliser la cle PUBLISHABLE / anon (sb_publishable_...), PAS la cle secrete.

SUPABASE_URL = "https://xxxxxxxxxxxx.supabase.co"
SUPABASE_KEY = "sb_publishable_xxxxxxxxxxxxxxxxxxxx"

# Optionnel : LLM (laisser de cote si non utilise en prod)
# LLM_BASE_URL = ""
# LLM_MODEL = ""
# USE_LLM_AGENT = "0"
